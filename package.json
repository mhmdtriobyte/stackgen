{
  "name": "stackgen",
  "version": "1.0.0",
  "description": "Opinionated full-stack project scaffolder",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "stackgen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ejs": "^3.1.10",
    "execa": "^9.3.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "scaffolder",
    "generator",
    "fullstack",
    "nextjs",
    "vite",
    "express",
    "drizzle",
    "typescript",
    "react",
    "project-generator",
    "boilerplate",
    "starter",
    "template"
  ],
  "author": "Mohammad Issa (@mhmd.triobyte)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhmdtriobyte/stackgen.git"
  },
  "bugs": {
    "url": "https://github.com/mhmdtriobyte/stackgen/issues"
  },
  "homepage": "https://github.com/mhmdtriobyte/stackgen#readme",
  "files": [
    "dist",
    "src/templates",
    "LICENSE",
    "README.md"
  ]
}
