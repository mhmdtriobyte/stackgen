import { z } from 'zod';

/**
 * Environment variable schema definition
 * All environment variables must be validated against this schema
 */
const envSchema = z.object({
  // Application
  NODE_ENV: z.enum(['development', 'test', 'production']).default('development'),
  PORT: z.coerce.number().positive().default(<%= port || 3000 %>),
<% if (frontend === 'nextjs') { -%>
  NEXT_PUBLIC_APP_URL: z.string().url().optional(),
<% } else { -%>
  APP_URL: z.string().url().optional(),
<% } -%>

  // Database
<% if (database === 'postgresql') { -%>
  DATABASE_URL: z
    .string()
    .url()
    .refine(
      (url) => url.startsWith('postgresql://') || url.startsWith('postgres://'),
      'DATABASE_URL must be a valid PostgreSQL connection string'
    ),
  DIRECT_URL: z.string().url().optional(),
<% } else if (database === 'mysql') { -%>
  DATABASE_URL: z
    .string()
    .url()
    .refine(
      (url) => url.startsWith('mysql://'),
      'DATABASE_URL must be a valid MySQL connection string'
    ),
<% } else if (database === 'sqlite') { -%>
  DATABASE_URL: z
    .string()
    .refine(
      (url) => url.startsWith('file:') || url.endsWith('.db'),
      'DATABASE_URL must be a valid SQLite file path'
    ),
<% } else { -%>
  DATABASE_URL: z.string().min(1, 'DATABASE_URL is required'),
<% } -%>

<% if (auth && auth !== 'none') { -%>
  // Authentication
  AUTH_SECRET: z
    .string()
    .min(32, 'AUTH_SECRET must be at least 32 characters long'),
  AUTH_URL: z.string().url().optional(),
  AUTH_TRUST_HOST: z
    .string()
    .transform((val) => val === 'true')
    .default('false'),

<% if (auth === 'google' || auth === 'oauth') { -%>
  // Google OAuth
  GOOGLE_CLIENT_ID: z.string().optional(),
  GOOGLE_CLIENT_SECRET: z.string().optional(),
<% } -%>

<% if (auth === 'github' || auth === 'oauth') { -%>
  // GitHub OAuth
  GITHUB_CLIENT_ID: z.string().optional(),
  GITHUB_CLIENT_SECRET: z.string().optional(),
<% } -%>

<% if (auth === 'discord' || auth === 'oauth') { -%>
  // Discord OAuth
  DISCORD_CLIENT_ID: z.string().optional(),
  DISCORD_CLIENT_SECRET: z.string().optional(),
<% } -%>
<% } -%>

<% if (features && features.includes('email')) { -%>
  // Email
  SMTP_HOST: z.string().optional(),
  SMTP_PORT: z.coerce.number().positive().default(587),
  SMTP_USER: z.string().optional(),
  SMTP_PASSWORD: z.string().optional(),
  SMTP_FROM: z.string().email().optional(),
<% } -%>

<% if (features && features.includes('redis')) { -%>
  // Redis
  REDIS_URL: z.string().url().optional(),
<% } -%>

<% if (features && features.includes('s3')) { -%>
  // AWS S3
  AWS_ACCESS_KEY_ID: z.string().optional(),
  AWS_SECRET_ACCESS_KEY: z.string().optional(),
  AWS_REGION: z.string().default('us-east-1'),
  S3_BUCKET_NAME: z.string().optional(),
<% } -%>

  // Logging
  LOG_LEVEL: z
    .enum(['debug', 'info', 'warn', 'error'])
    .default('info'),
});

/**
 * Type definition for validated environment variables
 */
export type Env = z.infer<typeof envSchema>;

/**
 * Validates and parses environment variables
 * Throws a helpful error if validation fails
 */
function validateEnv(): Env {
  const result = envSchema.safeParse(process.env);

  if (!result.success) {
    const errors = result.error.errors
      .map((err) => {
        const path = err.path.join('.');
        return `  - ${path}: ${err.message}`;
      })
      .join('\n');

    console.error('\n[ENV ERROR] Invalid environment variables:');
    console.error(errors);
    console.error('\nPlease check your .env file and ensure all required variables are set.\n');

    throw new Error('Environment validation failed');
  }

  return result.data;
}

/**
 * Validated environment variables
 * Import this object to access type-safe environment variables
 *
 * @example
 * import { env } from '@/env';
 * console.log(env.DATABASE_URL);
 */
export const env = validateEnv();

/**
 * Check if running in development mode
 */
export const isDevelopment = env.NODE_ENV === 'development';

/**
 * Check if running in production mode
 */
export const isProduction = env.NODE_ENV === 'production';

/**
 * Check if running in test mode
 */
export const isTest = env.NODE_ENV === 'test';
