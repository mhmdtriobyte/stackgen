# ==============================================================================
# Docker Compose Configuration for <%= projectName %>
# ==============================================================================
# Usage:
#   Development: docker-compose up -d
#   Production:  docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# ==============================================================================

version: '3.8'

services:
  # ----------------------------------------------------------------------------
  # Application Service
  # ----------------------------------------------------------------------------
  app:
    build:
      context: .
      dockerfile: Dockerfile
      target: runner
    container_name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-app
    restart: unless-stopped
    ports:
      - '${PORT:-<%= port || 3000 %>}:<%= port || 3000 %>'
    environment:
      - NODE_ENV=${NODE_ENV:-production}
      - PORT=<%= port || 3000 %>
      - DATABASE_URL=${DATABASE_URL}
<% if (auth && auth !== 'none') { -%>
      - AUTH_SECRET=${AUTH_SECRET}
      - AUTH_URL=${AUTH_URL}
<% } -%>
<% if (database === 'postgresql') { -%>
    depends_on:
      postgres:
        condition: service_healthy
<% } else if (database === 'mysql') { -%>
    depends_on:
      mysql:
        condition: service_healthy
<% } -%>
<% if (features && features.includes('redis')) { -%>
      redis:
        condition: service_healthy
<% } -%>
    networks:
      - <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-network
    healthcheck:
      test: ['CMD', 'wget', '--no-verbose', '--tries=1', '--spider', 'http://localhost:<%= port || 3000 %>/health']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

<% if (database === 'postgresql') { -%>
  # ----------------------------------------------------------------------------
  # PostgreSQL Database
  # ----------------------------------------------------------------------------
  postgres:
    image: postgres:16-alpine
    container_name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-postgres
    restart: unless-stopped
    ports:
      - '${POSTGRES_PORT:-5432}:5432'
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-password}
      POSTGRES_DB: ${POSTGRES_DB:-<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>}
      PGDATA: /var/lib/postgresql/data/pgdata
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-network
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U ${POSTGRES_USER:-postgres} -d ${POSTGRES_DB:-<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>}']
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

<% } else if (database === 'mysql') { -%>
  # ----------------------------------------------------------------------------
  # MySQL Database
  # ----------------------------------------------------------------------------
  mysql:
    image: mysql:8.0
    container_name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-mysql
    restart: unless-stopped
    ports:
      - '${MYSQL_PORT:-3306}:3306'
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD:-password}
      MYSQL_DATABASE: ${MYSQL_DATABASE:-<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>}
      MYSQL_USER: ${MYSQL_USER:-app}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD:-password}
    volumes:
      - mysql-data:/var/lib/mysql
    networks:
      - <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-network
    healthcheck:
      test: ['CMD', 'mysqladmin', 'ping', '-h', 'localhost', '-u', 'root', '-p${MYSQL_ROOT_PASSWORD:-password}']
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

<% } -%>
<% if (features && features.includes('redis')) { -%>
  # ----------------------------------------------------------------------------
  # Redis Cache
  # ----------------------------------------------------------------------------
  redis:
    image: redis:7-alpine
    container_name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-redis
    restart: unless-stopped
    ports:
      - '${REDIS_PORT:-6379}:6379'
    command: redis-server --appendonly yes --requirepass ${REDIS_PASSWORD:-}
    volumes:
      - redis-data:/data
    networks:
      - <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-network
    healthcheck:
      test: ['CMD', 'redis-cli', 'ping']
      interval: 10s
      timeout: 5s
      retries: 5

<% } -%>
# ------------------------------------------------------------------------------
# Networks
# ------------------------------------------------------------------------------
networks:
  <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-network:
    driver: bridge
    name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-network

# ------------------------------------------------------------------------------
# Volumes
# ------------------------------------------------------------------------------
volumes:
<% if (database === 'postgresql') { -%>
  postgres-data:
    name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-postgres-data
<% } else if (database === 'mysql') { -%>
  mysql-data:
    name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-mysql-data
<% } -%>
<% if (features && features.includes('redis')) { -%>
  redis-data:
    name: <%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '-') %>-redis-data
<% } -%>
