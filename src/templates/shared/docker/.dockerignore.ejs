# ==============================================================================
# Docker Ignore File
# ==============================================================================
# Files and directories listed here will not be sent to the Docker daemon
# during the build process, reducing build time and image size.
# ==============================================================================

# Dependencies (will be installed in Docker)
node_modules/
.pnpm-store/

# Build outputs (will be created in Docker)
dist/
build/
.next/
out/

# Development files
.git/
.gitignore
.github/

# IDE and editor files
.idea/
.vscode/
*.sublime-*
*.swp
*.swo
*~

# Environment files (use Docker secrets or env vars instead)
.env
.env.*
!.env.example

# Documentation
*.md
!README.md
docs/
LICENSE

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/
jest.config.*
vitest.config.*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Database files (use Docker volumes instead)
*.db
*.sqlite
*.sqlite3
data/
postgres-data/
mysql-data/

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Secrets (never include in images)
*.pem
*.key
*.crt
secrets/
credentials/

# Misc
.turbo/
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo
tmp/
temp/

# Storybook
storybook-static/
.storybook/

# Husky (not needed in container)
.husky/

# Debug
.debug/
debug.log
