#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}Running pre-commit checks...${NC}"

# Run lint-staged for formatting and linting staged files
echo "\n${YELLOW}[1/2] Running lint-staged...${NC}"
<% if (packageManager === 'pnpm') { -%>
pnpm lint-staged
<% } else if (packageManager === 'yarn') { -%>
yarn lint-staged
<% } else if (packageManager === 'bun') { -%>
bun run lint-staged
<% } else { -%>
npx lint-staged
<% } -%>

if [ $? -ne 0 ]; then
  echo "${RED}Lint-staged failed. Please fix the errors and try again.${NC}"
  exit 1
fi

echo "${GREEN}Lint-staged passed!${NC}"

# Run type check
echo "\n${YELLOW}[2/2] Running type check...${NC}"
<% if (packageManager === 'pnpm') { -%>
pnpm type-check
<% } else if (packageManager === 'yarn') { -%>
yarn type-check
<% } else if (packageManager === 'bun') { -%>
bun run type-check
<% } else { -%>
npm run type-check
<% } -%>

if [ $? -ne 0 ]; then
  echo "${RED}Type check failed. Please fix the type errors and try again.${NC}"
  exit 1
fi

echo "${GREEN}Type check passed!${NC}"

echo "\n${GREEN}All pre-commit checks passed! Committing...${NC}"
