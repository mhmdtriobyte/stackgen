# ==============================================================================
# Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files with real values to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=<%= port || 3000 %>
<% if (frontend === 'nextjs') { -%>
NEXT_PUBLIC_APP_URL=http://localhost:<%= port || 3000 %>
<% } else { -%>
APP_URL=http://localhost:<%= port || 3000 %>
<% } -%>

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
<% if (database === 'postgresql') { -%>
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>?schema=public"

# For connection pooling (Prisma)
# DIRECT_URL="postgresql://postgres:password@localhost:5432/<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>?schema=public"
<% } else if (database === 'mysql') { -%>
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/<%= projectName.toLowerCase().replace(/[^a-z0-9]/g, '_') %>"
<% } else if (database === 'sqlite') { -%>
# SQLite database file path
DATABASE_URL="file:./dev.db"
<% } else { -%>
# Database connection string
DATABASE_URL=""
<% } -%>

<% if (auth && auth !== 'none') { -%>
# ------------------------------------------------------------------------------
# Authentication (Auth.js / NextAuth.js)
# ------------------------------------------------------------------------------
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-generate-with-openssl"

# Auth.js URL (must match your app URL)
AUTH_URL=http://localhost:<%= port || 3000 %>

# Trust host for Auth.js (set to true in production behind a proxy)
AUTH_TRUST_HOST=true

<% if (auth === 'google' || auth === 'oauth') { -%>
# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

<% } -%>
<% if (auth === 'github' || auth === 'oauth') { -%>
# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

<% } -%>
<% if (auth === 'discord' || auth === 'oauth') { -%>
# Discord OAuth
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

<% } -%>
<% } -%>
# ------------------------------------------------------------------------------
# External Services (Optional)
# ------------------------------------------------------------------------------
<% if (features && features.includes('email')) { -%>
# Email (SMTP)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@example.com"

<% } -%>
<% if (features && features.includes('redis')) { -%>
# Redis
REDIS_URL="redis://localhost:6379"

<% } -%>
<% if (features && features.includes('s3')) { -%>
# AWS S3 / Object Storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME=""

<% } -%>
# ------------------------------------------------------------------------------
# Logging & Monitoring (Optional)
# ------------------------------------------------------------------------------
LOG_LEVEL=debug

# Sentry (Error Tracking)
# SENTRY_DSN=""

# Analytics
# ANALYTICS_ID=""

# ------------------------------------------------------------------------------
# Feature Flags (Optional)
# ------------------------------------------------------------------------------
# ENABLE_DEBUG_MODE=false
# ENABLE_MAINTENANCE_MODE=false
