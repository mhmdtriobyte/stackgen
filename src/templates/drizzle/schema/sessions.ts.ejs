 * - userId: Reference to the user who owns this session
 * - expiresAt: When the session expires (Unix timestamp)
 * - createdAt: When the session was created (Unix timestamp)
 *
 * Lucia manages session creation, validation, and cleanup.
 */
export const sessions = sqliteTable(
  'sessions',
  {
    id: text('id').primaryKey(),
    userId: text('user_id')
      .notNull()
      .references(() => users.id, { onDelete: 'cascade' }),
    expiresAt: integer('expires_at', { mode: 'timestamp' }).notNull(),
    createdAt: integer('created_at', { mode: 'timestamp' })
      .notNull()
      .default(sql`(unixepoch())`),
  },
  (table) => ({
    // Index on userId for finding all sessions for a user
    userIdIdx: index('sessions_user_id_idx').on(table.userId),
    // Index on expiresAt for cleanup queries
    expiresAtIdx: index('sessions_expires_at_idx').on(table.expiresAt),
  })
);
<% } else { -%>
/**
