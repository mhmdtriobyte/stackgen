import { Router, Response } from 'express';
import type { AuthenticatedRequest } from '../middleware/auth.js';

/**
 * Protected API routes
 * These routes require authentication (handled by authMiddleware)
 */
const router = Router();

/**
 * GET /api/protected/dashboard
 * Returns dashboard data for authenticated user
 */
router.get('/dashboard', (req: AuthenticatedRequest, res: Response) => {
  const user = req.user;

  res.json({
    message: `Welcome back, ${user?.name || user?.email || 'User'}!`,
    timestamp: new Date().toISOString(),
    stats: {
      users: 42, // Example stats
      sessions: 128,
    },
    user: {
      id: user?.id,
      email: user?.email,
      name: user?.name,
    },
  });
});

/**
 * GET /api/protected/profile
 * Returns the current user's profile
 */
router.get('/profile', (req: AuthenticatedRequest, res: Response) => {
  const user = req.user;

  if (!user) {
    return res.status(401).json({
      error: 'Not authenticated',
    });
  }

  res.json({
    user: {
      id: user.id,
      email: user.email,
      name: user.name,
      createdAt: user.createdAt,
    },
  });
});

/**
 * PUT /api/protected/profile
 * Updates the current user's profile
 */
router.put('/profile', async (req: AuthenticatedRequest, res: Response) => {
  const user = req.user;
  const { name } = req.body;

  if (!user) {
    return res.status(401).json({
      error: 'Not authenticated',
    });
  }

  // TODO: Implement profile update with database
  // For now, just return the updated data
  res.json({
    message: 'Profile updated successfully',
    user: {
      id: user.id,
      email: user.email,
      name: name || user.name,
    },
  });
});

/**
 * GET /api/protected/data
 * Returns protected data for the authenticated user
 */
router.get('/data', (req: AuthenticatedRequest, res: Response) => {
  const user = req.user;

  res.json({
    message: 'This is protected data',
    userId: user?.id,
    data: [
      { id: 1, name: 'Item 1', value: 100 },
      { id: 2, name: 'Item 2', value: 200 },
      { id: 3, name: 'Item 3', value: 300 },
    ],
    timestamp: new Date().toISOString(),
  });
});

export { router as protectedRouter };
